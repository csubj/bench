# Managed by chezmoi. Edit via: chezmoi edit ~/.gitconfig
[user]
	name = {{ .name }}
	email = {{ .email }}
[pull]
	rebase = true
# Prefer SSH for GitHub (auth via 1Password SSH agent in ~/.ssh/config).
[url "git@github.com:"]
	insteadOf = https://github.com/
[credential]
	helper = cache
[core]
	editor = code --wait
	# git also reads ~/.config/git/ignore by default (managed by chezmoi).
