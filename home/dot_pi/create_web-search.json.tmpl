{{- /* Pi web-search config. This is a `create_` entry: chezmoi seeds it
   ONCE if ~/.pi/web-search.json is missing, then never overwrites it. That
   protects a hand-maintained local file (e.g. openaiApiKey on a work box)
   from being stomped on apply. */ -}}
{{- if stat (joinPath .chezmoi.homeDir ".pi/web-search.local.json") -}}
{
  "braveApiKey": {{ onepasswordRead "op://homelab-cluster-secrets/brave-api-key/token" | quote }}
}
{{- else -}}
{}
{{- end -}}
