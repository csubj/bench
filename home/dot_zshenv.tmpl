# Managed by chezmoi. Loaded for every zsh invocation (login, interactive, scripts).
# Keep this minimal: environment only, no output, no interactive-only settings.

export EDITOR="code --wait"
export LANG="en_US.UTF-8"

# User-local binaries (npm global bin, pipx, etc.).
export PATH="$HOME/.local/bin:$PATH"

# Rust: Homebrew's rustup keeps cargo/rustc proxies in its keg (not ~/.cargo/bin).
for _rustup_bin in /opt/homebrew/opt/rustup/bin /usr/local/opt/rustup/bin "$HOME/.cargo/bin"; do
  [[ -d "$_rustup_bin" ]] && PATH="$_rustup_bin:$PATH"
done
unset _rustup_bin
export PATH

# 1Password SSH agent (symlinked to ~/.1password/agent.sock by chezmoi run_once hook).
if [[ -S "$HOME/.1password/agent.sock" ]]; then
  export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
fi
