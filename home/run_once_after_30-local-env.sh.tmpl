#!/usr/bin/env bash
# Scaffold machine-local, untracked config files with commented examples.
# run_once: runs once per machine. Never overwrites existing files, so real
# machine-local secrets/aliases/packages are preserved across re-applies.
set -euo pipefail

mkdir -p "$HOME/.config/zsh" "$HOME/.config/brew" "$HOME/.config/mcp"

LOCAL_ZSH="$HOME/.config/zsh/local.zsh"
if [[ ! -f "$LOCAL_ZSH" ]]; then
  echo "==> Scaffolding ${LOCAL_ZSH}"
  cat >"$LOCAL_ZSH" <<'LOCAL_ZSH_EOF'
# Machine-local zsh config: per-machine aliases and secrets.
# NEVER committed. Sourced last by ~/.zshrc so it can override anything.

# Put per-machine secrets, exports, and aliases here, e.g.:
# export SOME_API_KEY="..."
# alias deploy='...'
#
# On a work machine, use this for employer-specific env vars and aliases.
# Keep anything org-specific out of the bench repo.
LOCAL_ZSH_EOF
  chmod 600 "$LOCAL_ZSH"
fi

BREWFILE_LOCAL="$HOME/.config/brew/Brewfile.local"
if [[ ! -f "$BREWFILE_LOCAL" ]]; then
  echo "==> Scaffolding ${BREWFILE_LOCAL}"
  cat >"$BREWFILE_LOCAL" <<'BREWFILE_LOCAL_EOF'
# Machine-local Homebrew packages. NEVER committed.
# Applied by the run_onchange brew-bundle hook after the shared Brewfile.
#
# Use this on a work machine for employer-specific taps, internal tools, and
# job-specific stacks. Keep anything org-specific out of the bench repo.
#
# Examples (uncomment what this machine needs).
# Homebrew 6+ requires non-official taps to be trusted — use trusted: true
# on the tap, or install fully-qualified names (user/tap/formula).
# tap "hashicorp/tap", trusted: true
# brew "hashicorp/tap/vault"
# brew "azure-cli"
# tap "your-org/private-tap", trusted: true
# brew "kubernetes-cli"
# brew "helm"
# brew "k9s"
# brew "glab"
# cask "freelens"
BREWFILE_LOCAL_EOF
fi

MCP_LOCAL="$HOME/.config/mcp/mcp.local.json"
if [[ ! -f "$MCP_LOCAL" ]]; then
  echo "==> Scaffolding ${MCP_LOCAL}"
  # Machine-local MCP servers (tokens, corp endpoints). NEVER committed.
  # Merged into ~/.config/mcp/mcp.json by the mcp.json.tmpl template.
  # Example:
  # {
  #   "mcpServers": {
  #     "grafana": {
  #       "command": "uvx",
  #       "args": ["mcp-grafana"],
  #       "env": {
  #         "GRAFANA_URL": "https://grafana.example.com/",
  #         "GRAFANA_SERVICE_ACCOUNT_TOKEN": "glsa_..."
  #       }
  #     }
  #   }
  # }
  cat >"$MCP_LOCAL" <<'MCP_LOCAL_EOF'
{
  "mcpServers": {}
}
MCP_LOCAL_EOF
  chmod 600 "$MCP_LOCAL"
fi

# Optional: enable Pi Brave Search (pulls key from 1Password at chezmoi apply).
#   mkdir -p "$HOME/.pi" && touch "$HOME/.pi/web-search.local.json" && chmod 600 "$HOME/.pi/web-search.local.json"
