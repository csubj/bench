#!/usr/bin/env bash
# Symlink the 1Password SSH agent socket to a stable path for ~/.ssh/config.
# Requires: 1Password app with SSH agent enabled (Settings -> Developer).
set -euo pipefail

AGENT_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
LINK="$HOME/.1password/agent.sock"

mkdir -p "$HOME/.1password"

if [[ -S "$AGENT_SOCK" ]]; then
  ln -sf "$AGENT_SOCK" "$LINK"
  echo "Linked 1Password SSH agent: $LINK"
else
  echo "1Password SSH agent socket not found at:" >&2
  echo "  $AGENT_SOCK" >&2
  echo "Enable it in 1Password -> Settings -> Developer -> Use the SSH agent." >&2
fi
